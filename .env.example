# Nexus Agent 环境变量配置模板
# 复制此文件为 .env 并填入实际值

# ============================================
# 飞书通知配置
# ============================================
# 飞书 Webhook URL (从飞书机器人设置获取)
# 获取方式: 飞书开放平台 → 应用 → 你的应用 → 机器人 → 添加机器人 → 获取 Webhook 地址
FEISHU_WEBHOOK_URL="https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# ============================================
# GitHub 配置
# ============================================
# GitHub Personal Access Token (需要 repo 权限)
# 获取方式: GitHub → Settings → Developer settings → Personal access tokens → Tokens (classic) → Generate new token
# 权限要求: repo (完整仓库访问)
GITHUB_TOKEN="ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ============================================
# MiniMax API 配置
# ============================================
# MiniMax API Key (用于 AI 能力)
# 获取方式: https://platform.minimaxi.com/
MINIMAX_API_KEY="your-minimax-api-key-here"

# ============================================
# REST API 服务器配置
# ============================================
# API 服务器端口 (默认: 3000)
NEXUS_API_PORT="3000"

# API Key (用于认证，请修改为安全的随机字符串)
NEXUS_API_KEY="your-secure-api-key-change-me"

# ============================================
# 可选配置
# ============================================
# 日志级别 (debug, info, warn, error)
LOG_LEVEL="info"

# 是否启用通知 (true/false)
NOTIFICATION_ENABLED="true"
