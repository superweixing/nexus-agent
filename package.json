{
  "name": "nexus-agent",
  "version": "1.0.0",
  "description": "Nexus Agent - OpenClaw 管理模块",
  "main": "src/main.ts",
  "scripts": {
    "start": "ts-node src/main.ts start",
    "stop": "ts-node src/main.ts stop",
    "restart": "ts-node src/main.ts restart",
    "status": "ts-node src/main.ts status",
    "backup": "ts-node scripts/backup-cli.ts",
    "backup:check": "ts-node scripts/backup-cli.ts check",
    "backup:list": "ts-node scripts/backup-cli.ts list",
    "backup:restore": "ts-node scripts/backup-cli.ts restore",
    "test": "ts-node src/test/example.ts",
    "test:run": "ts-node -e \"import { SelfTester } from './src/test/self_tester'; new SelfTester().runFullValidation().then(r => console.log(JSON.stringify(r, null, 2)))\"",
    "self-test": "ts-node -e \"import { SelfTester } from './src/test/self_tester'; new SelfTester({ openclawPath: './openclaw' }).runFullValidation().then(r => console.log(r.canProceed ? '✓ 测试通过' : '✗ 测试失败'))\"",
    "lint": "eslint src --ext .ts,.js",
    "lint:fix": "eslint src --ext .ts,.js --fix",
    "format": "prettier --write \"src/**/*.{ts,js,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json}\"",
    "typecheck": "tsc --noEmit",
    "validate": "npm run typecheck && npm run lint && npm run format:check",
    "prepare": "cd .. && husky install"
  },
  "dependencies": {
    "@types/node": "^20.0.0",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "cron": "^4.4.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  },
  "devDependencies": {
    "@types/body-parser": "^1.19.6",
    "@types/cors": "^2.8.19",
    "@types/cron": "^2.0.1",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json}": [
      "prettier --write"
    ]
  }
}
